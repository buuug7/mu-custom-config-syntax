{
  "name": "mu-custom-config-syntax",
  "displayName": "MU Server Custom Config Syntax",
  "description": "Provides syntax highlighting for MU server custom config files in Data/Custom.",
  "version": "0.0.1",
  "publisher": "buuug7",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/buuug7/mu-custom-config-syntax",
  "bugs": {
    "url": "https://github.com/buuug7/mu-custom-config-syntax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/buuug7/mu-custom-config-syntax.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package",
    "publish": "npx vsce publish"
  },
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "keywords": [
    "mu",
    "muonline",
    "mu online",
    "mu server",
    "mu custom config",
    "mu配置",
    "奇迹",
    "syntax highlight"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mu-custom-config",
        "aliases": ["MU Custom Config", "MU Custom"],
        "extensions": [],
        "filenamePatterns": ["**/*.dat.txt"],
        "configuration": "language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mu-custom-config",
        "scopeName": "source.mu-custom-config",
        "path": "syntaxes/mu-custom-config.tmLanguage.json"
      }
    ]
  }
}
